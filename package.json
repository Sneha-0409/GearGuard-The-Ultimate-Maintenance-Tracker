{
  "name": "gearguard",
  "version": "1.0.0",
  "description": "GearGuard - Ultimate Maintenance Tracker",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install-all": "npm install && cd client && npm install",
    "seed": "node server/scripts/seedAdmin.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^7.8.8",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.7",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.8.0",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "maintenance",
    "asset-management",
    "tracker"
  ],
  "author": "",
  "license": "MIT"
}
