  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.5.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
