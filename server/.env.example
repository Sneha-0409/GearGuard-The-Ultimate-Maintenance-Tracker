# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/gearguard

# Server Configuration
PORT=5555
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Authentication JWT
JWT_SECRET=your_super_secret_jwt_key_here

# OAuth2 Single Sign-On (Google)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth2 Single Sign-On (Microsoft)
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here

# Optional SSO Configuration (Comma separated whitelist domains)
ALLOWED_SSO_DOMAINS=example.com,mycompany.com

# Email / SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM="GearGuard Notifications <noreply@example.com>"
